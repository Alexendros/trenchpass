# ─── TrenchPass · variables de entorno ──────────────────────────────────────────
# Copia a `.env` (gitignored) y rellena. Producción: inyectar vía Dokploy/Vault.

# ─── Server ──────────────────────────────────────────────────────────────────
TRENCHPASS_BIND=0.0.0.0:8300
TRENCHPASS_LOG_LEVEL=info,trenchpass=debug
TRENCHPASS_ENV=development               # development | staging | production

# TLS (PR3 mTLS · activar tras Vault PKI)
TRENCHPASS_TLS_CERT=/certs/server.crt
TRENCHPASS_TLS_KEY=/certs/server.key
TRENCHPASS_TLS_CLIENT_CA=/certs/vault-ca.crt
TRENCHPASS_MTLS_REQUIRED=false

# ─── Vault OSS ───────────────────────────────────────────────────────────────
VAULT_ADDR=https://vault.controlink.alexendros.me
VAULT_TOKEN=                              # AppRole token o root (dev)
VAULT_KV_MOUNT=secret
VAULT_PKI_MOUNT=pki
VAULT_CACHE_TTL_SECS=60

# ─── Postgres audit log ──────────────────────────────────────────────────────
DATABASE_URL=postgres://audit_writer:CHANGE_IN_ENV@postgres-audit:5432/audit
DATABASE_MAX_CONNECTIONS=8

# ─── OpenTelemetry → SigNoz ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=trenchpass
OTEL_RESOURCE_ATTRIBUTES=service.namespace=alexendros,deployment.environment=development

# ─── Proton Pass sync (PR4) ──────────────────────────────────────────────────
PROTON_PASS_CLI_BIN=/usr/local/bin/protonpass-cli
PROTON_PASS_VAULT_ID=
PROTON_PASS_DRIFT_INTERVAL_SECS=3600

# ─── Vía fax · IMAP Proton (PR7) ─────────────────────────────────────────────
FAX_IMAP_HOST=imap.protonmail.ch
FAX_IMAP_PORT=993
FAX_IMAP_USER=
FAX_IMAP_PASSWORD=
FAX_PGP_OPERATOR_FINGERPRINT=
FAX_POLL_INTERVAL_SECS=60

# ─── ManitasFritas (PR8) ─────────────────────────────────────────────────────
MFRITAS_HEARTBEAT_INTERVAL_DAYS=30
MFRITAS_ALERT_DAYS=60
MFRITAS_DISPARO_DAYS=90

# ─── Auth ────────────────────────────────────────────────────────────────────
# Bearer tokens de consumidores con scopes JSON; en producción se leen de Vault
# en `secret/consumers/<id>`. Para desarrollo, pueden inyectarse aquí (no usar en prod).
TRENCHPASS_DEV_BEARER=                       # opcional, solo TRENCHPASS_ENV=development
